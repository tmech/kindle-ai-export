AMAZON_EMAIL=
AMAZON_PASSWORD=
ASIN=

OPENAI_API_KEY=

TRANSCRIBE_PROVIDER=foundrylocal
TRANSCRIBE_MODEL=qwen3-vl-2b-instruct
TRANSCRIBE_MAX_RETRIES=20
TRANSCRIBE_CONCURRENCY=2
TRANSCRIBE_DETECT_FIGURES=true
TRANSCRIBE_MIN_FIGURE_AREA_RATIO=0.015
TRANSCRIBE_MIN_FIGURE_EDGE=80
TRANSCRIBE_MIN_FIGURE_STDEV=6
TRANSCRIBE_MIN_TEXT_BOX_CONFIDENCE=15

FOUNDRY_LOCAL_APP_NAME=kindle-ai-export
FOUNDRY_LOCAL_LOG_LEVEL=warn
# Optional: pin a specific Foundry model variant id.
# If unset, transcription auto-selects a GPU variant when available.
FOUNDRY_LOCAL_MODEL_VARIANT=
